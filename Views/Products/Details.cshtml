@model StoreManagementSystem.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

            <div class="bg-primary py-2"></div>

            <div class="card-body p-5">
                <h2 class="fw-bold text-dark mb-4 text-center">@Model.ProductName</h2>

                <hr class="text-muted mb-4" />

                <dl class="row align-items-center mb-0">

                    <dt class="col-sm-5 text-muted fw-semibold mb-3">Unit Price</dt>
                    <dd class="col-sm-7 mb-3">
                        <span class="fs-4 fw-bold text-success">R @Html.DisplayFor(model => model.Price)</span>
                    </dd>

                    <dt class="col-sm-5 text-muted fw-semibold mb-3">Current Stock</dt>
                    <dd class="col-sm-7 mb-3">
                        <span class="badge bg-secondary rounded-pill px-3 py-2 fs-6">
                            @Html.DisplayFor(model => model.StockQuantity) Units
                        </span>
                    </dd>

                    <dt class="col-sm-5 text-muted fw-semibold mb-3">Assigned Category</dt>
                    <dd class="col-sm-7 mb-3">
                        <span class="fw-semibold text-dark">
                            @Html.DisplayFor(model => model.Category.CategoryName)
                        </span>
                    </dd>
                </dl>

                <hr class="text-muted mt-3 mb-4" />

                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Edit" asp-route-id="@Model?.ProductId" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm">
                        Edit Product
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary fw-semibold rounded-pill px-4">
                        Back to List
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>