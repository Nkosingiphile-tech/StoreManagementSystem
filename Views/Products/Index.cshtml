@model IEnumerable<StoreManagementSystem.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-secondary">Inventory Management</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <strong>Success!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<form method="get" asp-action="Index" class="mb-3 d-flex">
    <input type="text" name="searchString" class="form-control me-2" placeholder="Search products..." value="@ViewData["CurrentFilter"]" />
    <button type="submit" class="btn btn-primary">Search</button>
</form>
<div class="card shadow-sm border-0 rounded-3">

    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between">
        <h5 class="mb-0 text-primary">All Products</h5>
        <div>
            <a asp-action="Create" class="btn btn-primary btn-sm fw-bold shadow-sm">
                + Add New Product
            </a>
            <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary btn-sm ms-2">
                Manage Categories
            </a>
        </div>
    </div>

    <div class="card-body p-0 mt-3">
        <table class="table table-hover table-borderless align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">@Html.DisplayNameFor(model => model.ProductName)</th>
                    <th>@Html.DisplayNameFor(model => model.Price)</th>
                    <th>Stock</th>
                    <th>Category</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold text-dark">@Html.DisplayFor(modelItem => item.ProductName)</td>

                        <td class="text-success fw-bold">R @Html.DisplayFor(modelItem => item.Price)</td>

                        <td>
                            <span class="badge bg-secondary rounded-pill px-3 py-2">
                                @Html.DisplayFor(modelItem => item.StockQuantity)
                            </span>
                        </td>

                        <td>@Html.DisplayFor(modelItem => item.Category.CategoryName)</td>

                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-info me-1">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>