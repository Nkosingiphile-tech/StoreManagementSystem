@model StoreManagementSystem.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 text-center">
                <h3 class="fw-bold text-primary">Add New Product</h3>
                <p class="text-muted small">Enter the product details below to add it to your central inventory.</p>
            </div>

            <div class="card-body p-4 p-md-5 pt-0">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="ProductName" class="form-control bg-light border-0" placeholder="e.g. Wireless Mouse" />
                        <label asp-for="ProductName" class="text-muted">Product Name</label>
                        <span asp-validation-for="ProductName" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <label asp-for="Price" class="form-label text-muted small fw-bold ms-1 mb-1">Price</label>
                            <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden">
                                <span class="input-group-text bg-light border-0 text-muted fw-bold">R</span>
                                <input asp-for="Price" type="number" step="0.01" class="form-control bg-light border-0" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StockQuantity" class="form-label text-muted small fw-bold ms-1 mb-1">Stock Quantity</label>
                            <input asp-for="StockQuantity" type="number" class="form-control form-control-lg bg-light border-0 shadow-sm" placeholder="0" />
                            <span asp-validation-for="StockQuantity" class="text-danger small fw-bold"></span>
                        </div>
                    </div>

                    <div class="mb-5">
                        <label asp-for="CategoryId" class="form-label text-muted small fw-bold ms-1 mb-1">Assign Category</label>
                        <select asp-for="CategoryId" class="form-select form-select-lg bg-light border-0 shadow-sm text-secondary" asp-items="ViewBag.CategoryId">
                            <option value="">-- Select a Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <input type="submit" value="Save Product" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm" />
                        <a asp-action="Index" class="btn btn-light btn-lg fw-semibold rounded-pill text-muted mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}