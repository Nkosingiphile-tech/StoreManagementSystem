@model IEnumerable<StoreManagementSystem.Models.Product>
@{
    ViewData["Title"] = "Home";
}

<style>
    .product-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1px solid #e0e0e0;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        cursor: pointer;
    }
    .product-image-container {
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
        overflow: hidden;
    }
    .product-image-container img {
        max-height: 100%;
        object-fit: contain;
    }
    .price-tag {
        font-size: 1.25rem;
        font-weight: 800;
        color: #b12704; /* Amazon Red */
    }
</style>

<div id="homePromoCarousel" class="carousel slide mb-5 shadow-sm rounded overflow-hidden" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active" style="background-color: #0d6efd; height: 350px;">
            <div class="container h-100 d-flex align-items-center">
                <div class="text-white col-md-6">
                    <h1 class="fw-bold display-5">Up to 50% Off Top Tech</h1>
                    <p class="lead">Upgrade your setup with the latest enterprise software and hardware.</p>
                    <a href="#" class="btn btn-warning btn-lg fw-bold mt-2">Shop the Sale</a>
                </div>
            </div>
        </div>
        <div class="carousel-item" style="background-color: #212529; height: 350px;">
            <div class="container h-100 d-flex align-items-center">
                <div class="text-white col-md-6">
                    <h1 class="fw-bold display-5">New Arrivals are Here</h1>
                    <p class="lead">Discover the newest tools for developers and IT professionals.</p>
                    <a href="#" class="btn btn-light btn-lg fw-bold mt-2">Explore Now</a>
                </div>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#homePromoCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#homePromoCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="container-fluid mb-5">
    <h3 class="fw-bold mb-4 border-bottom pb-2">Featured Products</h3>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 product-card rounded-3">
                        
                        <div class="product-image-container rounded-top-3">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="img-fluid p-3" alt="@item.ProductName">
                            }
                            else
                            {
                                <div class="bg-light w-100 h-100 d-flex justify-content-center align-items-center">
                                    <i class="bi bi-laptop text-secondary" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title text-truncate fw-bold mb-1">@item.ProductName</h6>
                            <p class="small text-muted mb-2 text-truncate" title="@item.Description">
                                @(string.IsNullOrEmpty(item.Description) ? "Enterprise Tech Hardware/Software" : item.Description)
                            </p>
                            
                            <div class="mb-2 text-warning small">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                            </div>
                            
                            <div class="price-tag mt-auto">@item.Price.ToString("C")</div>
                            
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-3 ajax-cart-form">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn btn-warning w-100 fw-bold rounded-pill shadow-sm">Add to Cart</button>
                        </form>
                            
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-box-seam text-muted mb-3" style="font-size: 3rem;"></i>
                <h5 class="text-muted fw-bold">No products available right now.</h5>
                <p class="text-muted">The Admin needs to add products to the catalog!</p>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Listen for any form with the 'ajax-cart-form' class to be submitted
            $('.ajax-cart-form').on('submit', function(e) {
                e.preventDefault(); // STOP the page from reloading!

                var form = $(this);
                var url = form.attr('action');
                var data = form.serialize();

                // Send the data to the server in the background
                $.post(url, data, function(response) {
                    if (response.success) {
                        
                        // 1. Find the cart badge and update the number
                        var badge = $('#cart-badge');
                        badge.text(response.newCount);
                        
                        // 2. If it was gray (0), turn it yellow!
                        if (response.newCount > 0) {
                            badge.removeClass('bg-secondary text-light').addClass('bg-warning text-dark');
                        }

                        // 3. Show a beautiful green popup notification
                        toastr.success(response.message, 'Success 🛒', { 
                            "positionClass": "toast-bottom-right",
                            "timeOut": "3000"
                        });
                    }
                });
            });
        });
    </script>
}