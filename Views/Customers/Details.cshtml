@model StoreManagementSystem.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">

            <div class="bg-info py-2"></div>

            <div class="card-body p-5 text-center">

                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center mx-auto shadow-sm mb-3"
                     style="width: 80px; height: 80px; font-size: 2rem; font-weight: bold;">
                    @Model.FirstName.Substring(0, 1)@Model.LastName.Substring(0, 1)
                </div>

                <h2 class="fw-bold text-dark mb-1">@Model.FirstName @Model.LastName</h2>
                <p class="text-muted mb-4">Client Profile</p>

                <hr class="text-muted mb-4" />

                <dl class="row text-start align-items-center mb-0 px-md-4">

                    <dt class="col-sm-4 text-muted fw-semibold mb-3">Email Address</dt>
                    <dd class="col-sm-8 mb-3 fw-bold">
                        <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
                    </dd>

                    <dt class="col-sm-4 text-muted fw-semibold mb-3">Phone Number</dt>
                    <dd class="col-sm-8 mb-3">
                        @if (string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <span class="badge bg-light text-secondary border">Not Provided</span>
                        }
                        else
                        {
                            <span class="fw-semibold text-dark">@Model.PhoneNumber</span>
                        }
                    </dd>
                </dl>

                <hr class="text-muted mt-3 mb-4" />

                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Edit" asp-route-id="@Model?.CustomerId" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm">
                        Edit Profile
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary fw-semibold rounded-pill px-4">
                        Back to Directory
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>