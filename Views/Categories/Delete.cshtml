@model StoreManagementSystem.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="container mt-4">
    <h2 class="text-danger">Delete Category</h2>
    <h4>Are you sure you want to permanently delete this category?</h4>
    <hr />

    <dl class="row mt-4">
        <dt class="col-sm-3">Category Name</dt>
        <dd class="col-sm-9 fw-bold">@Html.DisplayFor(model => model.CategoryName)</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

        <dt class="col-sm-3">Is Active?</dt>
        <dd class="col-sm-9">@(Model.IsActive == true ? "Yes" : "No")</dd>
    </dl>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="CategoryId" />
        <input type="submit" value="Confirm Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>