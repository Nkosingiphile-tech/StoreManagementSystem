@model StoreManagementSystem.Models.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 text-center">
                <h3 class="fw-bold text-primary">Edit Category</h3>
                <p class="text-muted small">Update the naming and details for this category.</p>
            </div>

            <div class="card-body p-4 p-md-5 pt-0">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="CategoryId" />

                    <div class="form-floating mb-4">
                        <input asp-for="CategoryName" class="form-control bg-light border-0" placeholder="Category Name" />
                        <label asp-for="CategoryName" class="text-muted">Category Name</label>
                        <span asp-validation-for="CategoryName" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <input type="submit" value="Save Changes" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm" />
                        <a asp-action="Index" class="btn btn-light btn-lg fw-semibold rounded-pill text-muted mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}