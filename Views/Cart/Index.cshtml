@model IEnumerable<StoreManagementSystem.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
    decimal subtotal = Model?.Sum(item => item.Quantity * item.Product.Price) ?? 0;
    // Standard 15% VAT calculation
    decimal vat = subtotal * 0.15m;
    decimal total = subtotal + vat;
}

<div class="container my-5">
    <h2 class="fw-bold mb-4">Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 text-center py-5">
            <div class="card-body">
                <i class="bi bi-cart-x text-muted mb-3" style="font-size: 4rem;"></i>
                <h4 class="fw-bold">Your cart is empty</h4>
                <p class="text-muted mb-4">Looks like you haven't added any tech or software yet.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold">
                    Start Shopping
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="mb-0 fw-bold">Cart Items (@Model.Count())</h5>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model)
                            {
                                <li class="list-group-item p-4">
                                    <div class="row align-items-center">
                                        
                                        <div class="col-md-2 col-4 text-center">
                                            @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.ProductName" class="img-fluid rounded shadow-sm" style="max-height: 80px;" />
                                            }
                                            else
                                            {
                                                <div class="bg-light rounded d-flex align-items-center justify-content-center shadow-sm" style="height: 80px; width: 100%;">
                                                    <i class="bi bi-box text-secondary fs-3"></i>
                                                </div>
                                            }
                                        </div>

                                        <div class="col-md-5 col-8">
                                            <h6 class="fw-bold mb-1">@item.Product.ProductName</h6>
                                            <p class="text-muted small mb-0 text-truncate">@item.Product.Description</p>
                                        </div>

                                        <div class="col-md-3 col-6 mt-3 mt-md-0 text-md-center">
                                            <div class="text-muted small mb-1">Qty: <strong>@item.Quantity</strong></div>
                                            <div class="fw-bold text-dark">@item.Product.Price.ToString("C")</div>
                                        </div>

                                        <div class="col-md-2 col-6 mt-3 mt-md-0 text-end">
                                            <form asp-action="Remove" method="post">
                                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                                    <i class="bi bi-trash3"></i> Remove
                                                </button>
                                            </form>
                                        </div>

                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 position-sticky" style="top: 2rem;">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="mb-0 fw-bold">Order Summary</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-semibold">@subtotal.ToString("C")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">VAT (15%)</span>
                            <span class="fw-semibold">@vat.ToString("C")</span>
                        </div>
                        <hr class="my-4">
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 fw-bold">Total</span>
                            <span class="fs-5 fw-bold text-success">@total.ToString("C")</span>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <a href="#" class="btn btn-primary btn-lg fw-bold rounded-pill text-uppercase letter-spacing shadow-sm">
                                Proceed to Checkout
                            </a>
                            <div class="text-center mt-2 small text-muted">
                                <i class="bi bi-shield-lock-fill text-success"></i> Secure 256-bit SSL encryption
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>