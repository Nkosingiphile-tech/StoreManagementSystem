@{
    ViewData["Title"] = "Order Successful";
}

<div class="container text-center my-5 py-5">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 6rem; text-shadow: 0 4px 15px rgba(25, 135, 84, 0.3);"></i>
    </div>
    
    <h1 class="fw-bold mb-3">Thank You For Your Purchase!</h1>
    
    <p class="text-muted lead mb-5 mx-auto" style="max-width: 600px;">
        Your order has been successfully placed and paid for. Our warehouse team is packing your tech right now. You can view your order details in your account dashboard.
    </p>
    
    <a asp-controller="Shop" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm">
        <i class="bi bi-bag me-2"></i> Continue Shopping
    </a>
</div>