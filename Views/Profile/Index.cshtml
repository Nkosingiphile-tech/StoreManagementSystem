@model StoreManagementSystem.Models.Customer
@{
    ViewData["Title"] = "My Account";
}

<div class="container my-5">
    <div class="row">
        
        <!-- Left Sidebar Navigation -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 text-center bg-dark text-white">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 80px; height: 80px; font-size: 2.5rem;">
                        <i class="bi bi-person"></i>
                    </div>
                    <h4 class="fw-bold mb-1">@(string.IsNullOrEmpty(Model.FirstName) ? "Welcome!" : Model.FirstName)</h4>
                    <p class="text-white-50 small mb-0">@Model.Email</p>
                </div>
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action active py-3 fw-semibold"><i class="bi bi-person-lines-fill me-2"></i> Profile & Address</a>
                    <a asp-controller="Orders" asp-action="Index" class="list-group-item list-group-item-action py-3 fw-semibold text-muted"><i class="bi bi-box-seam me-2"></i> My Orders</a>
                    
                    <!-- Links to Identity's built-in change password page -->
                    <a href="/Identity/Account/Manage/ChangePassword" class="list-group-item list-group-item-action py-3 fw-semibold text-muted"><i class="bi bi-shield-lock me-2"></i> Change Password</a>
                </div>
            </div>
        </div>

        <!-- Right Side - The Form -->
        <div class="col-lg-8">
            
            <!-- Warning Banner if Address is Missing -->
            @if (string.IsNullOrEmpty(Model.StreetAddress))
            {
                <div class="alert alert-warning border-0 shadow-sm rounded-3 d-flex align-items-center p-4 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill fs-3 text-warning me-3"></i>
                    <div>
                        <h5 class="fw-bold text-dark mb-1">Action Required</h5>
                        <p class="mb-0 text-dark opacity-75">Please update your delivery address before proceeding to checkout.</p>
                    </div>
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="fw-bold mb-0">Personal Details & Delivery Address</h5>
                </div>
                <div class="card-body p-4 p-md-5">
                    
                    <form asp-action="UpdateProfile" method="post">
                        
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-semibold small">First Name</label>
                                <input asp-for="FirstName" class="form-control bg-light border-0 py-2" required placeholder="John" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-semibold small">Last Name</label>
                                <input asp-for="LastName" class="form-control bg-light border-0 py-2" required placeholder="Doe" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted fw-semibold small">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control bg-light border-0 py-2" required placeholder="082 123 4567" />
                        </div>

                        <h6 class="fw-bold mb-3 border-top pt-4">Shipping Address</h6>

                        <div class="mb-3">
                            <label class="form-label text-muted fw-semibold small">Street Address</label>
                            <input asp-for="StreetAddress" class="form-control bg-light border-0 py-2" required placeholder="123 Main Street, Appt 4B" />
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-semibold small">City / Suburb</label>
                                <input asp-for="City" class="form-control bg-light border-0 py-2" required placeholder="Summerstrand, Gqeberha" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted fw-semibold small">Postal Code</label>
                                <input asp-for="PostalCode" class="form-control bg-light border-0 py-2" required placeholder="6001" />
                            </div>
                        </div>

                        <div class="text-end mt-4">
                            <button type="submit" class="btn btn-dark fw-bold px-5 py-2 rounded-pill shadow-sm">Save Changes</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Toastr Alert for successful saves -->
    <script>
        $(document).ready(function() {
            var successMsg = '@TempData["Success"]';
            var warningMsg = '@TempData["Warning"]';
            
            if(successMsg) {
                toastr.success(successMsg, 'Saved!', { "positionClass": "toast-bottom-right" });
            }
            if(warningMsg) {
                toastr.warning(warningMsg, 'Wait!', { "positionClass": "toast-bottom-right", "timeOut": "6000" });
            }
        });
    </script>
}