@model StoreManagementSystem.Models.Product

@{
    ViewData["Title"] = Model.ProductName;
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Index" class="text-decoration-none fw-semibold">Catalog</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="row g-0">
            
            <div class="col-md-6 bg-light d-flex align-items-center justify-content-center p-5">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm" alt="@Model.ProductName" style="max-height: 450px; object-fit: contain;">
                }
                else
                {
                    <i class="bi bi-laptop text-muted opacity-25" style="font-size: 10rem;"></i>
                }
            </div>

            <div class="col-md-6 p-5">
                <span class="badge bg-secondary bg-opacity-10 text-secondary text-uppercase letter-spacing mb-3 px-3 py-2">
                    @(Model.Category?.CategoryName ?? "Enterprise Tech")
                </span>
                
                <h2 class="fw-bold text-dark mb-2">@Model.ProductName</h2>
                
                <div class="mb-4 text-warning">
                    <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                    <span class="text-muted ms-2 small fw-semibold">(Verified Reviews)</span>
                </div>

                <hr class="text-muted my-4" />

                <h3 class="text-danger fw-bold mb-4" style="font-size: 2.5rem;">@Model.Price.ToString("C")</h3>

                <p class="text-muted lh-lg mb-4">
                    @(string.IsNullOrEmpty(Model.Description) ? "Experience premium performance with this enterprise-grade solution. Designed for professionals who demand the best in reliability and speed." : Model.Description)
                </p>

                <div class="d-flex align-items-center mb-4">
                    @if (Model.StockQuantity > 5)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2"><i class="bi bi-check-circle-fill me-1"></i> In Stock (@Model.StockQuantity available)</span>
                    }
                    else if (Model.StockQuantity > 0)
                    {
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-3 py-2"><i class="bi bi-exclamation-circle-fill me-1"></i> Low Stock (Only @Model.StockQuantity left!)</span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2"><i class="bi bi-x-circle-fill me-1"></i> Out of Stock</span>
                    }
                </div>

                <div class="bg-light p-4 rounded-4 mt-4">
                    @if (Model.StockQuantity > 0)
                    {
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="ajax-cart-form">
                            <input type="hidden" name="productId" value="@Model.ProductId" />
                            
                            <div class="row g-3 align-items-center">
                                <div class="col-sm-4 col-md-3">
                                    <label class="form-label text-muted fw-bold small mb-1">Quantity</label>
                                    <input type="number" name="quantity" class="form-control form-control-lg text-center fw-bold" value="1" min="1" max="@Model.StockQuantity">
                                </div>
                                <div class="col-sm-8 col-md-9 mt-auto">
                                    <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold rounded-pill shadow-sm">
                                        <i class="bi bi-cart-plus me-2"></i> Add to Cart
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg w-100 fw-bold rounded-pill opacity-50" disabled>Currently Unavailable</button>
                    }
                </div>

                <div class="d-flex justify-content-center gap-4 mt-4 text-muted small">
                    <span><i class="bi bi-shield-check text-success fs-5"></i> Secure Checkout</span>
                    <span><i class="bi bi-truck text-primary fs-5"></i> Fast Delivery</span>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.ajax-cart-form').on('submit', function(e) {
                e.preventDefault(); 
                var form = $(this);
                $.post(form.attr('action'), form.serialize(), function(response) {
                    if (response.success) {
                        var badge = $('#cart-badge');
                        badge.text(response.newCount);
                        if (response.newCount > 0) {
                            badge.removeClass('bg-secondary text-light').addClass('bg-warning text-dark');
                        }
                        toastr.success(response.message, 'Success 🛒', { "positionClass": "toast-bottom-right", "timeOut": "3000" });
                    }
                });
            });
        });
    </script>
}