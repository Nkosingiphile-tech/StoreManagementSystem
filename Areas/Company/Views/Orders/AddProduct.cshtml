@model StoreManagementSystem.Models.OrderDetail

@{
    ViewData["Title"] = "Add Product to Order";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                <div class="display-4 mb-2">📦</div>
                <h4 class="fw-bold text-primary mb-1">Add to Order #@ViewBag.OrderId</h4>
                <p class="text-muted small">Select an item from inventory to add to this invoice.</p>
            </div>

            <div class="card-body p-4 p-md-5 pt-3">
                <form asp-area="Company" asp-controller="Orders" asp-action="AddProduct">
                    <input type="hidden" name="OrderId" value="@ViewBag.OrderId" />

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold ms-1 mb-1">Select Product</label>
                        <select asp-for="ProductId" class="form-select form-select-lg bg-light border-0 shadow-sm" asp-items="ViewBag.ProductId">
                            <option value="">-- Choose a Product --</option>
                        </select>
                    </div>

                    <div class="mb-5">
                        <label class="form-label text-muted small fw-bold ms-1 mb-1">Quantity</label>
                        <input asp-for="Quantity" type="number" class="form-control form-control-lg bg-light border-0 shadow-sm" value="1" min="1" />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill shadow-sm">+ Add to Invoice</button>
                        <a asp-area="Company" asp-controller="Orders" asp-action="Details" asp-route-id="@ViewBag.OrderId" class="btn btn-light btn-lg w-100 mt-2 rounded-pill text-muted fw-semibold">Back to Order Details</a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}