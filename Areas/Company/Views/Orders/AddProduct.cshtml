@model StoreManagementSystem.Models.OrderDetail

@{
    ViewData["Title"] = "Add Product to Order";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <h4 class="fw-bold text-primary mb-4">Add Product to Order #@ViewBag.OrderId</h4>
                <form asp-action="AddProduct">
                    <input type="hidden" name="OrderId" value="@ViewBag.OrderId" />

                    <div class="mb-3">
                        <label class="form-label">Select Product</label>
                        <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId"></select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Quantity</label>
                        <input asp-for="Quantity" type="number" class="form-control" value="1" min="1" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill">Add to Order</button>
                    <a asp-action="Details" asp-route-id="@ViewBag.OrderId" class="btn btn-light w-100 mt-2 rounded-pill">Back to Order</a>
                </form>
            </div>
        </div>
    </div>
</div>