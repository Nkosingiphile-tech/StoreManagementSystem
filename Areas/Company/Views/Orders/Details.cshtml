@model StoreManagementSystem.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Invoice #@Model.OrderId</h2>
            <p class="text-muted mb-0">Date: @Model.OrderDate?.ToString("MMMM dd, yyyy")</p>
        </div>
        <div>
            <a asp-area="Company" asp-controller="Orders" asp-action="Index" class="btn btn-outline-secondary fw-bold rounded-pill px-4 shadow-sm">
                Back to Sales List
            </a>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 p-4 h-100">
                <h5 class="fw-bold text-primary mb-4">Order Summary</h5>

                <div class="mb-4">
                    <p class="text-muted small mb-1">Customer</p>
                    <h6 class="fw-bold mb-0">@Model.Customer.FirstName @Model.Customer.LastName</h6>
                    <a href="mailto:@Model.Customer.Email" class="text-decoration-none small">@Model.Customer.Email</a>
                </div>

                <div class="p-3 bg-light rounded-4 border-0 mb-4">
                    <label class="fw-bold text-dark small mb-2">Update Order Status:</label>
                    <form asp-area="Company" asp-controller="Orders" asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                        <input type="hidden" name="orderId" value="@Model.OrderId" />

                        <select asp-for="OrderStatus" class="form-select border-0 shadow-sm text-secondary">
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>

                        <button type="submit" class="btn btn-primary fw-bold px-3 shadow-sm rounded-3">Save</button>
                    </form>
                </div>

                <hr class="text-muted" />

                <div class="mt-auto">
                    <p class="text-muted small mb-1">Total Amount Due</p>
                    <h3 class="fw-bold text-success mb-0">R @Model.TotalAmount.ToString("N2")</h3>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">

                <div class="card-header bg-white border-bottom-0 p-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0">Line Items</h5>
                    <a asp-area="Company" asp-controller="Orders" asp-action="AddProduct" asp-route-id="@Model.OrderId" class="btn btn-primary btn-sm fw-bold rounded-pill px-3 shadow-sm">
                        + Add Product
                    </a>
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted">
                            <tr>
                                <th class="ps-4 fw-semibold">Product</th>
                                <th class="fw-semibold">Unit Price</th>
                                <th class="fw-semibold text-center">Qty</th>
                                <th class="text-end pe-4 fw-semibold">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                            {
                                foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">@item.Product.ProductName</td>
                                        <td class="text-muted">R @item.UnitPrice.ToString("N2")</td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary bg-opacity-25 text-dark px-2 py-1">@item.Quantity</span>
                                        </td>
                                        <td class="text-end pe-4 fw-bold text-success">
                                            R @((item.Quantity * item.UnitPrice).ToString("N2"))
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-5">
                                        <div class="display-6 mb-2 opacity-50">🛒</div>
                                        No items have been added to this order yet.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
</div>