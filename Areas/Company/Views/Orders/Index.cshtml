@model IEnumerable<StoreManagementSystem.Models.Order>

@{
    ViewData["Title"] = "Sales Orders";
}

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }

    .action-icons a, .action-icons button {
        margin-right: 8px;
        transition: transform 0.2s;
    }

        .action-icons a:hover, .action-icons button:hover {
            transform: scale(1.1);
        }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">🛒 Sales Orders</h2>
        <a asp-area="Company" asp-controller="Orders" asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            + Create New Order
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4">
            <table id="ordersTable" class="table table-hover align-middle w-100 mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="fw-semibold ps-4">Order #</th>
                        <th class="fw-semibold">Customer</th>
                        <th class="fw-semibold">Date</th>
                        <th class="fw-semibold">Status</th>
                        <th class="fw-semibold text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark ps-4">#@item.OrderId</td>
                            <td>@item.Customer.FirstName @item.Customer.LastName</td>
                            <td class="text-muted">@item.OrderDate?.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (item.OrderStatus == "Completed")
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2">Completed</span>
                                }
                                else if (item.OrderStatus == "Cancelled")
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2">Cancelled</span>
                                }
                                else if (item.OrderStatus == "Pending")
                                {
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark rounded-pill px-3 py-2">@item.OrderStatus</span>
                                }
                            </td>
                            <td class="text-end pe-4 action-icons">
                                <a asp-area="Company" asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-primary rounded-pill px-3 fw-bold shadow-sm">Manage</a>
                                <a asp-area="Company" asp-controller="Orders" asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-secondary rounded-circle" title="Edit">✏️</a>

                                <button type="button" class="btn btn-sm btn-outline-danger rounded-circle" onclick="confirmDelete(@item.OrderId)" title="Delete">🗑️</button>

                                <form id="delete-form-@item.OrderId" asp-area="Company" asp-controller="Orders" asp-action="Delete" asp-route-id="@item.OrderId" method="post" class="d-none"></form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $('#ordersTable').DataTable({
                "pageLength": 10,
                "order": [[0, "desc"]], /* Sorts newest orders first by default */
                "language": {
                    "search": "Search Orders:"
                }
            });

            var successMessage = '@TempData["SuccessMessage"]';
            if (successMessage) {
                toastr.success(successMessage, 'Success', {
                    "positionClass": "toast-bottom-right",
                    "timeOut": "3000"
                });
            }
        });

        function confirmDelete(orderId) {
            Swal.fire({
                title: 'Delete Order?',
                text: "You are about to permanently delete Order #" + orderId + ". This cannot be undone!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-form-' + orderId).submit();
                }
            })
        }
    </script>
}