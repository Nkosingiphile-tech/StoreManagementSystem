@model StoreManagementSystem.Models.Order

@{
    ViewData["Title"] = "Create New Order";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 text-center">
                <h3 class="fw-bold text-primary">New Order</h3>
                <p class="text-muted small">Create a new sales transaction below.</p>
            </div>

            <div class="card-body p-4 p-md-5 pt-0">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="CustomerId" class="form-label text-muted small fw-bold ms-1 mb-1">Select Customer</label>
                        <select asp-for="CustomerId" class="form-select form-select-lg bg-light border-0 shadow-sm" asp-items="ViewBag.CustomerId"></select>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="OrderStatus" class="form-control bg-light border-0" placeholder="Status" />
                        <label asp-for="OrderStatus" class="text-muted">Order Status (e.g. Pending)</label>
                    </div>

                    <div class="d-grid gap-2">
                        <input type="submit" value="Create Order" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm" />
                        <a asp-action="Index" class="btn btn-light btn-lg fw-semibold rounded-pill text-muted mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}