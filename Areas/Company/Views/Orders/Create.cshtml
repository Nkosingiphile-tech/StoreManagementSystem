@model StoreManagementSystem.Models.Order

@{
    ViewData["Title"] = "Create New Order";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 text-center">
                <div class="display-4 mb-2">🛒</div>
                <h3 class="fw-bold text-primary">New Sales Order</h3>
                <p class="text-muted small">Select a customer to begin a new transaction.</p>
            </div>

            <div class="card-body p-4 p-md-5 pt-0">
                <form asp-area="Company" asp-controller="Orders" asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="CustomerId" class="form-label text-muted small fw-bold ms-1 mb-1">Select Customer</label>
                        <select asp-for="CustomerId" class="form-select form-select-lg bg-light border-0 shadow-sm text-secondary" asp-items="ViewBag.CustomerId">
                            <option value="">-- Choose a Customer --</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="mb-5">
                        <label asp-for="OrderStatus" class="form-label text-muted small fw-bold ms-1 mb-1">Initial Order Status</label>
                        <select asp-for="OrderStatus" class="form-select form-select-lg bg-light border-0 shadow-sm text-secondary">
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Completed">Completed</option>
                        </select>
                        <span asp-validation-for="OrderStatus" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <input type="submit" value="Create Order Shell" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm" />
                        <a asp-area="Company" asp-controller="Orders" asp-action="Index" class="btn btn-light btn-lg fw-semibold rounded-pill text-muted mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}