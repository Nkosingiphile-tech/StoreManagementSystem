@model StoreManagementSystem.Models.Order

@{
    ViewData["Title"] = "Edit Order";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 text-center">
                <h3 class="fw-bold text-primary">Edit Order #@Model.OrderId</h3>
            </div>
            <div class="card-body p-4 p-md-5 pt-0">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="OrderId" />

                    <div class="form-floating mb-4">
                        <select asp-for="CustomerId" class="form-select bg-light border-0" asp-items="ViewBag.CustomerId"></select>
                        <label class="text-muted">Customer</label>
                    </div>

                    <div class="form-floating mb-4">
                        <select asp-for="OrderStatus" class="form-select bg-light border-0">
                            <option value="Pending">Pending</option>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <label asp-for="OrderStatus" class="text-muted">Order Status</label>
                    </div>

                    <div class="d-grid gap-2">
                        <input type="submit" value="Save Changes" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm" />
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill text-muted mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>