@model StoreManagementSystem.Models.Order

@{
    ViewData["Title"] = "Delete Order";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-danger rounded-4">
            <div class="bg-danger py-2 rounded-top"></div>
            <div class="card-body p-5 text-center">
                <div class="display-4 mb-3">🗑️</div>
                <h3 class="fw-bold text-danger">Delete Order #@Model.OrderId?</h3>
                <p class="text-muted mb-4">This action will permanently remove this order and its details. This cannot be undone.</p>

                <div class="bg-light p-3 rounded mb-4">
                    <p class="mb-0"><strong>Customer:</strong> @Model.Customer.FirstName @Model.Customer.LastName</p>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="OrderId" />
                    <div class="d-flex justify-content-center gap-3">
                        <input type="submit" value="Delete Forever" class="btn btn-danger px-4 rounded-pill fw-bold" />
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>