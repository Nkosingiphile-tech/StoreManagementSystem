@model StoreManagementSystem.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 text-center">
                <h3 class="fw-bold text-primary">Create New Category</h3>
                <p class="text-muted small">Fill out the details below to add a new category to your inventory system.</p>
            </div>

            <div class="card-body p-4 p-md-5 pt-0">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="CategoryName" class="form-control bg-light border-0" placeholder="e.g. Electronics" />
                        <label asp-for="CategoryName" class="text-muted">Category Name</label>
                        <span asp-validation-for="CategoryName" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Description" class="form-control bg-light border-0" placeholder="Description" style="height: 120px"></textarea>
                        <label asp-for="Description" class="text-muted">Description (Optional)</label>
                        <span asp-validation-for="Description" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="form-check form-switch mb-5 ms-1">
                        <input class="form-check-input" type="checkbox" role="switch" id="IsActive" name="IsActive" value="true" checked style="transform: scale(1.3);">
                        <label class="form-check-label fw-semibold ms-2 mt-1" for="IsActive">Set as Active Category</label>
                    </div>

                    <div class="d-grid gap-2">
                        <input type="submit" value="Save Category" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm" />
                        <a asp-action="Index" class="btn btn-light btn-lg fw-semibold rounded-pill text-muted mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}