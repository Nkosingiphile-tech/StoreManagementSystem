@model IEnumerable<StoreManagementSystem.Models.Product>

@{
    ViewData["Title"] = "Manage Products";
}

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }

    .action-icons a, .action-icons button {
        margin-right: 8px;
        transition: transform 0.2s;
    }

        .action-icons a:hover, .action-icons button:hover {
            transform: scale(1.1);
        }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">📦 Product Inventory</h2>
        <a asp-area="Company" asp-controller="Products" asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            + Add New Product
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4">
            <table id="productsTable" class="table table-hover align-middle w-100">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="fw-semibold">Product Name</th>
                        <th class="fw-semibold">Category</th>
                        <th class="fw-semibold">Price</th>
                        <th class="fw-semibold">Stock</th>
                        <th class="fw-semibold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.ProductName</td>
                            <td><span class="badge bg-secondary bg-opacity-25 text-dark">@item.Category?.CategoryName</span></td>
                            <td class="text-success fw-bold">R @item.Price.ToString("0.00")</td>
                            <td>
                                @if (item.StockQuantity <= 5)
                                {
                                    <span class="badge bg-danger">@item.StockQuantity Left!</span>
                                }
                                else
                                {
                                    <span class="text-muted">@item.StockQuantity</span>
                                }
                            </td>
                            <td class="text-end action-icons">
                                <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary rounded-circle" title="Edit">✏️</a>
                                <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-info rounded-circle" title="Details">📄</a>

                                <button type="button" class="btn btn-sm btn-outline-danger rounded-circle" onclick="confirmDelete(@item.ProductId, '@item.ProductName')" title="Delete">🗑️</button>

                                <form id="delete-form-@item.ProductId" asp-action="Delete" asp-route-id="@item.ProductId" method="post" class="d-none">
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // 1. Initialize DataTables (Instantly adds Search & Pagination)
            $('#productsTable').DataTable({
                "pageLength": 10,
                "language": {
                    "search": "Search Inventory:"
                }
            });

            // 2. Check for TempData and trigger Toastr Notification
            var successMessage = '@TempData["SuccessMessage"]';
            if (successMessage) {
                toastr.success(successMessage, 'Success', {
                    "positionClass": "toast-bottom-right",
                    "timeOut": "3000"
                });
            }
        });

        // 3. SweetAlert Delete Confirmation Logic
        function confirmDelete(productId, productName) {
            Swal.fire({
                title: 'Are you sure?',
                text: "You are about to delete " + productName + ". This cannot be undone!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Submit the hidden form for this specific product
                    document.getElementById('delete-form-' + productId).submit();
                }
            })
        }
    </script>
}