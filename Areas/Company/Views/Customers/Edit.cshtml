@model StoreManagementSystem.Models.Customer

@{
    ViewData["Title"] = "Edit Customer";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-2 text-center">
                <div class="display-4 mb-2">👤</div>
                <h3 class="fw-bold text-primary">Edit Customer</h3>
                <p class="text-muted small">Update the contact information for this client.</p>
            </div>

            <div class="card-body p-4 p-md-5 pt-0">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="CustomerId" />

                    <div class="row mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <div class="form-floating">
                                <input asp-for="FirstName" class="form-control bg-light border-0" placeholder="Jane" />
                                <label asp-for="FirstName" class="text-muted">First Name</label>
                                <span asp-validation-for="FirstName" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="LastName" class="form-control bg-light border-0" placeholder="Doe" />
                                <label asp-for="LastName" class="text-muted">Last Name</label>
                                <span asp-validation-for="LastName" class="text-danger small fw-bold"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Email" type="email" class="form-control bg-light border-0" placeholder="name@example.com" />
                        <label asp-for="Email" class="text-muted">Email Address</label>
                        <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="form-floating mb-5">
                        <input asp-for="PhoneNumber" type="tel" class="form-control bg-light border-0" placeholder="082 123 4567" />
                        <label asp-for="PhoneNumber" class="text-muted">Phone Number (Optional)</label>
                        <span asp-validation-for="PhoneNumber" class="text-danger small fw-bold"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <input type="submit" value="Save Changes" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm" />
                        <a asp-area="Company" asp-controller="Customers" asp-action="Index" class="btn btn-light btn-lg fw-semibold rounded-pill text-muted mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}