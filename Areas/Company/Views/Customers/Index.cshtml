@model IEnumerable<StoreManagementSystem.Models.Customer>

@{
    ViewData["Title"] = "Customer Directory";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-secondary">Customer Directory</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <strong>Success!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0 rounded-3">

    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between">
        <h5 class="mb-0 text-primary">All Customers</h5>
        <div>
            <a asp-action="Create" class="btn btn-primary btn-sm fw-bold shadow-sm">
                + Add New Customer
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm ms-2">
                Back to Dashboard
            </a>
        </div>
    </div>

    <div class="card-body p-0 mt-3">
        <table class="table table-hover table-borderless align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Name</th>
                    <th>Email Address</th>
                    <th>Phone Number</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-dark">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm" style="width: 40px; height: 40px;">
                                    @item.FirstName.Substring(0, 1)@item.LastName.Substring(0, 1)
                                </div>
                                @Html.DisplayFor(modelItem => item.FirstName) @Html.DisplayFor(modelItem => item.LastName)
                            </div>
                        </td>

                        <td class="text-primary fw-semibold">
                            <a href="mailto:@item.Email" class="text-decoration-none">@Html.DisplayFor(modelItem => item.Email)</a>
                        </td>

                        <td class="text-muted">
                            @if (string.IsNullOrEmpty(item.PhoneNumber))
                            {
                                <span class="badge bg-light text-secondary border">No Phone</span>
                            }
                            else
                            {
                                @Html.DisplayFor(modelItem => item.PhoneNumber)
                            }
                        </td>

                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-info me-1">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>